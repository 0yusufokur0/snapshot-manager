#!/bin/bash
# snapshot-manager - rsync+hardlink snapshot system with GRUB restore
# Usage: snapshot-manager {create|list|delete|restore|verify|check|lock|unlock|diff|restore-file|archive|status|help}

set -euo pipefail

# Lock file for concurrent execution protection
LOCK_FILE="/var/run/snapshot-manager.lock"

# Load config
CONFIG_FILE="/etc/snapshot-manager.conf"
if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
fi

SNAPSHOT_DIR="${SNAPSHOT_DIR:-/snapshots}"
MAX_SYSTEM_SNAPSHOTS="${MAX_SYSTEM_SNAPSHOTS:-0}"
MAX_FULL_SNAPSHOTS="${MAX_FULL_SNAPSHOTS:-0}"
KEEP_DAILY="${KEEP_DAILY:-0}"
KEEP_WEEKLY="${KEEP_WEEKLY:-0}"
KEEP_MONTHLY="${KEEP_MONTHLY:-0}"
LOW_PRIORITY="${LOW_PRIORITY:-true}"
GENERATE_MANIFEST="${GENERATE_MANIFEST:-false}"

# Borg settings
ARCHIVE_MODE="${ARCHIVE_MODE:-none}"
BORG_REPO="${BORG_REPO:-}"
BORG_COMPRESSION="${BORG_COMPRESSION:-zstd,3}"
BORG_KEEP_DAILY="${BORG_KEEP_DAILY:-7}"
BORG_KEEP_WEEKLY="${BORG_KEEP_WEEKLY:-4}"
BORG_KEEP_MONTHLY="${BORG_KEEP_MONTHLY:-6}"
MAX_RECENT_RSYNC="${MAX_RECENT_RSYNC:-3}"

# Resolve borg repo path
if [[ -z "$BORG_REPO" ]]; then
    BORG_REPO="${SNAPSHOT_DIR}/.borg-repo"
fi

# Borg environment
export BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes
export BORG_RELOCATED_REPO_ACCESS_IS_OK=yes

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Common excludes (virtual/temp filesystems - always excluded)
ALWAYS_EXCLUDE=(
    "${SNAPSHOT_DIR}"
    "/proc/*"
    "/sys/*"
    "/dev/*"
    "/run/*"
    "/tmp/*"
    "/var/tmp/*"
    "/var/cache/*"
    "/var/log/*"
    "/var/lib/docker/*"
    "/var/lib/machines/*"
    "/mnt/*"
    "/media/*"
    "/snap/*"
    "/boot/efi/*"
    "/lost+found"
    "/swap.img"
    "/swapfile"
)

# Additional excludes for system-only snapshots
HOME_EXCLUDE=(
    "/home/*"
)

check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}Error: This script must be run as root.${NC}"
        echo "Usage: sudo snapshot-manager ..."
        exit 1
    fi
}

ensure_snapshot_dir() {
    if [[ ! -d "$SNAPSHOT_DIR" ]]; then
        mkdir -p "$SNAPSHOT_DIR"
        echo -e "${GREEN}Snapshot directory created: ${SNAPSHOT_DIR}${NC}"
    fi
}

# Build exclude args into RSYNC_EXCLUDE_ARGS array (avoids glob expansion issues)
build_exclude_args() {
    local type="$1"
    RSYNC_EXCLUDE_ARGS=()

    for exc in "${ALWAYS_EXCLUDE[@]}"; do
        RSYNC_EXCLUDE_ARGS+=(--exclude="$exc")
    done

    if [[ "$type" == "system" ]]; then
        for exc in "${HOME_EXCLUDE[@]}"; do
            RSYNC_EXCLUDE_ARGS+=(--exclude="$exc")
        done
    fi
}

# Build rsync command prefix with optional low priority
rsync_cmd() {
    if [[ "$LOW_PRIORITY" == "true" ]]; then
        ionice -c3 nice -n 19 /usr/bin/rsync "$@"
    else
        /usr/bin/rsync "$@"
    fi
}

# Acquire exclusive lock (prevents concurrent snapshot operations)
acquire_lock() {
    exec 9>"$LOCK_FILE"
    if ! flock -n 9; then
        echo -e "${RED}Error: Another snapshot-manager process is running.${NC}"
        echo -e "${RED}If you are sure it is not running: rm -f ${LOCK_FILE}${NC}"
        exit 1
    fi
}

release_lock() {
    flock -u 9 2>/dev/null
    rm -f "$LOCK_FILE" 2>/dev/null
}

is_locked() {
    local snap_path="$1"
    [[ -f "${snap_path}/info.conf" ]] && grep -q "^LOCKED=true" "${snap_path}/info.conf" 2>/dev/null
}

# ============================================================
# Borg helper functions
# ============================================================

borg_is_available() {
    command -v borg &>/dev/null
}

borg_check_available() {
    if ! borg_is_available; then
        echo -e "${RED}Error: borg is not installed.${NC}"
        echo -e "${YELLOW}Install with: sudo apt install borgbackup${NC}"
        return 1
    fi
}

borg_ensure_repo() {
    if [[ ! -d "$BORG_REPO" ]]; then
        echo -e "${YELLOW}Initializing borg repository: ${BORG_REPO}${NC}"
        borg init --encryption=none "$BORG_REPO"
        echo -e "${GREEN}Borg repository initialized.${NC}"
    fi
}

borg_cmd() {
    if [[ "$LOW_PRIORITY" == "true" ]]; then
        ionice -c3 nice -n 19 borg "$@"
    else
        borg "$@"
    fi
}

borg_archive_snapshot() {
    local snap_path="$1"
    local name="$2"

    if [[ "$ARCHIVE_MODE" != "borg" ]]; then
        return 0
    fi

    if ! borg_is_available; then
        echo -e "${YELLOW}Warning: borg not installed, skipping archive.${NC}"
        return 0
    fi

    borg_ensure_repo

    echo ""
    echo -e "${YELLOW}Archiving to borg repository...${NC}"

    local borg_exit=0
    # cd into fs/ so borg stores relative paths (etc/, usr/, not full absolute paths)
    (cd "${snap_path}/fs" && borg_cmd create \
        --compression "$BORG_COMPRESSION" \
        --progress \
        --stats \
        "${BORG_REPO}::${name}" \
        .) || borg_exit=$?

    if [[ $borg_exit -eq 0 || $borg_exit -eq 1 ]]; then
        echo -e "${GREEN}Borg archive created: ${name}${NC}"

        # Determine type for per-type prune
        local archive_type="system"
        if [[ "$name" == full_* ]]; then
            archive_type="full"
        fi
        borg_prune_archives "$archive_type"
    else
        echo -e "${RED}Warning: Borg archive failed (exit code: $borg_exit). rsync snapshot preserved.${NC}"
    fi
}

borg_prune_archives() {
    local type="${1:-}"
    echo -e "${YELLOW}Pruning borg archives...${NC}"

    # Prune per type (system/full separately) to avoid cross-type deletion
    local types_to_prune=()
    if [[ -n "$type" ]]; then
        types_to_prune=("$type")
    else
        types_to_prune=("system" "full")
    fi

    for t in "${types_to_prune[@]}"; do
        local prune_exit=0
        borg_cmd prune \
            --glob-archives "${t}_*" \
            --keep-daily="$BORG_KEEP_DAILY" \
            --keep-weekly="$BORG_KEEP_WEEKLY" \
            --keep-monthly="$BORG_KEEP_MONTHLY" \
            --stats \
            "$BORG_REPO" || prune_exit=$?

        if [[ $prune_exit -ne 0 ]]; then
            echo -e "${YELLOW}Warning: Borg prune (${t}) returned exit code: $prune_exit${NC}"
        fi
    done
}

cleanup_rsync_for_borg() {
    local type="$1"

    # In borg mode, keep only MAX_RECENT_RSYNC rsync snapshots per type
    local snapshots
    snapshots=$(find "$SNAPSHOT_DIR" -maxdepth 1 -name "${type}_*" -type d | sort -r)
    local count
    count=$(echo "$snapshots" | grep -c . || true)

    if [[ "$count" -gt "$MAX_RECENT_RSYNC" ]]; then
        local to_delete
        to_delete=$(echo "$snapshots" | tail -n +"$((MAX_RECENT_RSYNC + 1))")
        for old_snap in $to_delete; do
            if is_locked "$old_snap"; then
                echo -e "${YELLOW}Skipping locked snapshot: $(basename "$old_snap")${NC}"
                continue
            fi
            echo -e "${YELLOW}Removing old rsync snapshot (archived in borg): $(basename "$old_snap")${NC}"
            rm -rf "$old_snap"
        done
    fi
}

archive_to_borg() {
    local target="$1"
    check_root

    if ! borg_check_available; then
        exit 1
    fi

    # Path traversal protection
    if [[ "$target" == *"/"* || "$target" == *".."* ]]; then
        echo -e "${RED}Error: Invalid snapshot name: ${target}${NC}"
        exit 1
    fi

    local snap_path="${SNAPSHOT_DIR}/${target}"
    if [[ ! -d "$snap_path" || ! -d "${snap_path}/fs" ]]; then
        echo -e "${RED}Error: Snapshot not found: ${target}${NC}"
        exit 1
    fi

    acquire_lock
    trap release_lock EXIT

    borg_ensure_repo

    # Check if archive already exists
    if borg list --short "$BORG_REPO" 2>/dev/null | grep -qx "$target"; then
        echo -e "${YELLOW}Archive already exists in borg: ${target}${NC}"
        return 0
    fi

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Archiving snapshot${NC}"
    echo -e "${BLUE}  Name: ${target}${NC}"
    echo -e "${BLUE}============================================${NC}"
    echo ""

    local borg_exit=0
    # cd into fs/ so borg stores relative paths (etc/, usr/, not full absolute paths)
    (cd "${snap_path}/fs" && borg_cmd create \
        --compression "$BORG_COMPRESSION" \
        --progress \
        --stats \
        "${BORG_REPO}::${target}" \
        .) || borg_exit=$?

    if [[ $borg_exit -eq 0 || $borg_exit -eq 1 ]]; then
        echo ""
        echo -e "${GREEN}Successfully archived: ${target}${NC}"
    else
        echo -e "${RED}Error: Borg archive failed (exit code: $borg_exit)${NC}"
        exit 1
    fi
}

create_snapshot() {
    local type="${1:-system}"
    local description="${2:-}"

    if [[ "$type" != "system" && "$type" != "full" ]]; then
        echo -e "${RED}Error: Invalid type. Use 'system' or 'full'.${NC}"
        exit 1
    fi

    check_root
    ensure_snapshot_dir
    acquire_lock
    trap release_lock EXIT

    local timestamp
    timestamp=$(date +%Y-%m-%d_%H-%M-%S)
    local name="${type}_${timestamp}"
    local snap_path="${SNAPSHOT_DIR}/${name}"

    if [[ -z "$description" ]]; then
        if [[ "$type" == "system" ]]; then
            description="System backup - $(date '+%d %B %Y %H:%M')"
        else
            description="Full backup (including user files) - $(date '+%d %B %Y %H:%M')"
        fi
    fi

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Creating snapshot${NC}"
    echo -e "${BLUE}  Type: ${type}${NC}"
    echo -e "${BLUE}  Name: ${name}${NC}"
    if [[ "$LOW_PRIORITY" == "true" ]]; then
        echo -e "${BLUE}  Priority: Low (ionice+nice)${NC}"
    fi
    echo -e "${BLUE}============================================${NC}"
    echo ""

    mkdir -p "${snap_path}/fs"
    mkdir -p "${snap_path}/boot"

    # Find latest snapshot of same type for hardlink deduplication
    local link_dest=""
    local latest
    latest=$(find "$SNAPSHOT_DIR" -maxdepth 1 -name "${type}_*" -type d | sort -r | head -n1)
    if [[ -n "$latest" && -d "${latest}/fs" && "$latest" != "$snap_path" ]]; then
        link_dest="--link-dest=${latest}/fs"
        echo -e "${YELLOW}Using hardlinks from previous snapshot: $(basename "$latest")${NC}"
    fi

    # Build exclude arguments (populates RSYNC_EXCLUDE_ARGS array)
    build_exclude_args "$type"

    # Check available disk space before starting (snapshot disk, not root)
    local avail_kb used_kb
    avail_kb=$(df --output=avail "$SNAPSHOT_DIR" | tail -1 | tr -d ' ')
    used_kb=$(df --output=used / | tail -1 | tr -d ' ')
    # First snapshot needs ~used space, subsequent ones much less due to hardlinks
    if [[ -z "$link_dest" && "$avail_kb" -lt "$used_kb" ]]; then
        echo -e "${RED}Error: Not enough disk space!${NC}"
        echo -e "${RED}Required: ~$((used_kb / 1024 / 1024))GB, Available: $((avail_kb / 1024 / 1024))GB${NC}"
        rm -rf "${snap_path}"
        exit 1
    fi

    # Build rsync args as proper array (avoids glob expansion issues)
    local rsync_args=(-aAXH --one-file-system --delete --info=progress2)
    rsync_args+=("${RSYNC_EXCLUDE_ARGS[@]}")
    if [[ -n "$link_dest" ]]; then
        rsync_args+=("$link_dest")
    fi
    rsync_args+=(/ "${snap_path}/fs/")

    # Run rsync (--one-file-system prevents crossing mount boundaries)
    echo -e "${YELLOW}Copying files (rsync)...${NC}"
    local rsync_exit=0
    rsync_cmd "${rsync_args[@]}" || rsync_exit=$?

    # rsync exit code 24 = files vanished during transfer (normal on live system)
    # rsync exit code 23 = partial transfer (some files couldn't be read)
    if [[ $rsync_exit -ne 0 && $rsync_exit -ne 24 && $rsync_exit -ne 23 ]]; then
        echo -e "${RED}Error: rsync failed (exit code: $rsync_exit)${NC}"
        echo -e "${RED}Removing incomplete snapshot...${NC}"
        rm -rf "${snap_path}"
        exit 1
    fi

    if [[ $rsync_exit -eq 24 || $rsync_exit -eq 23 ]]; then
        echo -e "${YELLOW}Note: Some files changed during transfer (normal). Snapshot is valid.${NC}"
    fi

    # Copy current kernel and initramfs
    echo -e "${YELLOW}Copying kernel and initramfs...${NC}"
    local kernel_version
    kernel_version=$(uname -r)

    if [[ -f "/boot/vmlinuz-${kernel_version}" ]]; then
        cp "/boot/vmlinuz-${kernel_version}" "${snap_path}/boot/vmlinuz"
    elif [[ -f "/boot/vmlinuz" ]]; then
        cp "/boot/vmlinuz" "${snap_path}/boot/vmlinuz"
    else
        echo -e "${RED}Warning: Kernel file not found!${NC}"
    fi

    if [[ -f "/boot/initrd.img-${kernel_version}" ]]; then
        cp "/boot/initrd.img-${kernel_version}" "${snap_path}/boot/initrd.img"
    elif [[ -f "/boot/initrd.img" ]]; then
        cp "/boot/initrd.img" "${snap_path}/boot/initrd.img"
    else
        echo -e "${RED}Warning: initrd file not found!${NC}"
    fi

    # Generate SHA256 manifest if enabled
    if [[ "$GENERATE_MANIFEST" == "true" ]]; then
        echo -e "${YELLOW}Generating SHA256 manifest...${NC}"
        find "${snap_path}/fs" -type f -print0 2>/dev/null | \
            xargs -0 sha256sum > "${snap_path}/manifest.sha256" 2>/dev/null || true
        local manifest_count
        manifest_count=$(wc -l < "${snap_path}/manifest.sha256" 2>/dev/null || echo "0")
        echo -e "${GREEN}Manifest generated for ${manifest_count} files.${NC}"
    fi

    # Save metadata (description sanitized to prevent injection)
    local safe_description
    safe_description=$(echo "$description" | tr -d '\n\r')
    cat > "${snap_path}/info.conf" <<METAEOF
NAME=${name}
TYPE=${type}
DATE=${timestamp}
KERNEL=${kernel_version}
DESCRIPTION=${safe_description}
LOCKED=false
METAEOF

    echo ""
    echo -e "${GREEN}Snapshot created successfully: ${name}${NC}"

    # Disk usage
    local size
    size=$(du -sh "${snap_path}" 2>/dev/null | cut -f1)
    echo -e "${GREEN}Size: ${size}${NC}"

    # Archive to borg (if enabled)
    borg_archive_snapshot "$snap_path" "$name"

    # Cleanup old snapshots
    if [[ "$ARCHIVE_MODE" == "borg" ]]; then
        cleanup_rsync_for_borg "$type"
    else
        cleanup_snapshots "$type"
    fi

    # Update GRUB
    echo ""
    echo -e "${YELLOW}Updating GRUB menu...${NC}"
    if command -v update-grub &>/dev/null; then
        update-grub 2>&1 | tail -5
    elif command -v grub-mkconfig &>/dev/null; then
        grub-mkconfig -o /boot/grub/grub.cfg 2>&1 | tail -5
    fi
    echo -e "${GREEN}GRUB menu updated.${NC}"

    echo ""
    echo -e "${GREEN}============================================${NC}"
    echo -e "${GREEN}  Completed!${NC}"
    echo -e "${GREEN}============================================${NC}"
}

cleanup_snapshots() {
    local type="$1"

    # If keep policy is active, use it
    if [[ "$KEEP_DAILY" -gt 0 || "$KEEP_WEEKLY" -gt 0 || "$KEEP_MONTHLY" -gt 0 ]]; then
        cleanup_by_policy "$type"
        return
    fi

    # Otherwise use simple max count
    local max_count
    if [[ "$type" == "system" ]]; then
        max_count="$MAX_SYSTEM_SNAPSHOTS"
    else
        max_count="$MAX_FULL_SNAPSHOTS"
    fi

    local snapshots
    snapshots=$(find "$SNAPSHOT_DIR" -maxdepth 1 -name "${type}_*" -type d | sort -r)
    local count
    count=$(echo "$snapshots" | grep -c . || true)

    if [[ "$max_count" -gt 0 && "$count" -gt "$max_count" ]]; then
        local to_delete
        to_delete=$(echo "$snapshots" | tail -n +"$((max_count + 1))")
        for old_snap in $to_delete; do
            # Skip locked snapshots
            if is_locked "$old_snap"; then
                echo -e "${YELLOW}Skipping locked snapshot: $(basename "$old_snap")${NC}"
                continue
            fi
            echo -e "${YELLOW}Deleting old snapshot: $(basename "$old_snap")${NC}"
            rm -rf "$old_snap"
        done
    fi
}

cleanup_by_policy() {
    local type="$1"
    local snapshots
    snapshots=$(find "$SNAPSHOT_DIR" -maxdepth 1 -name "${type}_*" -type d | sort -r)

    [[ -z "$snapshots" ]] && return

    # Build set of snapshots to keep
    declare -A keep_set=()

    # Always keep locked snapshots
    for snap in $snapshots; do
        if is_locked "$snap"; then
            keep_set["$snap"]=1
        fi
    done

    # Keep daily: latest snapshot per day for last N days
    if [[ "$KEEP_DAILY" -gt 0 ]]; then
        local days_seen=0
        local last_day=""
        for snap in $snapshots; do
            local datepart
            datepart=$(basename "$snap" | sed "s/^${type}_//" | cut -d_ -f1)
            if [[ "$datepart" != "$last_day" ]]; then
                last_day="$datepart"
                days_seen=$((days_seen + 1))
                if [[ $days_seen -le $KEEP_DAILY ]]; then
                    keep_set["$snap"]=1
                fi
            fi
        done
    fi

    # Keep weekly: latest snapshot per week for last N weeks
    if [[ "$KEEP_WEEKLY" -gt 0 ]]; then
        local weeks_seen=0
        local last_week=""
        for snap in $snapshots; do
            local datepart
            datepart=$(basename "$snap" | sed "s/^${type}_//" | cut -d_ -f1)
            local week
            week=$(date -d "${datepart}" +%G-%V 2>/dev/null || echo "")
            if [[ -n "$week" && "$week" != "$last_week" ]]; then
                last_week="$week"
                weeks_seen=$((weeks_seen + 1))
                if [[ $weeks_seen -le $KEEP_WEEKLY ]]; then
                    keep_set["$snap"]=1
                fi
            fi
        done
    fi

    # Keep monthly: latest snapshot per month for last N months
    if [[ "$KEEP_MONTHLY" -gt 0 ]]; then
        local months_seen=0
        local last_month=""
        for snap in $snapshots; do
            local datepart
            datepart=$(basename "$snap" | sed "s/^${type}_//" | cut -d_ -f1)
            local month="${datepart:0:7}"
            if [[ "$month" != "$last_month" ]]; then
                last_month="$month"
                months_seen=$((months_seen + 1))
                if [[ $months_seen -le $KEEP_MONTHLY ]]; then
                    keep_set["$snap"]=1
                fi
            fi
        done
    fi

    # Delete snapshots not in keep set
    for snap in $snapshots; do
        if [[ -z "${keep_set[$snap]:-}" ]]; then
            echo -e "${YELLOW}Deleting per retention policy: $(basename "$snap")${NC}"
            rm -rf "$snap"
        fi
    done
}

list_snapshots() {
    ensure_snapshot_dir

    # Collect local (rsync) snapshots
    declare -A rsync_snaps=()
    local snapshots
    snapshots=$(find "$SNAPSHOT_DIR" -maxdepth 1 -mindepth 1 -type d ! -name ".*" 2>/dev/null | sort -r)
    for snap in $snapshots; do
        local bname
        bname=$(basename "$snap")
        rsync_snaps["$bname"]=1
    done

    # Collect archived snapshots
    declare -A borg_snaps=()
    if [[ -d "$BORG_REPO" ]] && borg_is_available; then
        while IFS= read -r aname; do
            [[ -n "$aname" ]] && borg_snaps["$aname"]=1
        done < <(borg list --short "$BORG_REPO" 2>/dev/null)
    fi

    # Build unified list of all names
    declare -A all_names=()
    for name in "${!rsync_snaps[@]}"; do
        all_names["$name"]=1
    done
    for name in "${!borg_snaps[@]}"; do
        all_names["$name"]=1
    done

    if [[ ${#all_names[@]} -eq 0 ]]; then
        echo -e "${YELLOW}No snapshots found.${NC}"
        return
    fi

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Available Snapshots${NC}"
    echo -e "${BLUE}============================================${NC}"
    echo ""

    printf "%-4s %-36s %-8s %-12s %-10s %-6s %s\n" "#" "NAME" "TYPE" "STORAGE" "SIZE" "LOCK" "DESCRIPTION"
    printf "%-4s %-36s %-8s %-12s %-10s %-6s %s\n" "---" "----" "----" "-------" "----" "----" "-----------"

    # Sort all names (reverse for newest first)
    local sorted_names
    sorted_names=$(printf '%s\n' "${!all_names[@]}" | sort -r)

    local i=1
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue

        local in_rsync=false in_borg=false
        [[ -n "${rsync_snaps[$name]:-}" ]] && in_rsync=true
        [[ -n "${borg_snaps[$name]:-}" ]] && in_borg=true

        # Determine storage location
        local storage
        if $in_rsync && $in_borg; then
            storage="local+arch"
        elif $in_rsync; then
            storage="local"
        else
            storage="archived"
        fi

        # Determine type
        local type_label="System"
        [[ "$name" == full_* ]] && type_label="Full"

        # Size, lock, description from local snapshot
        local size="-" lock_status="-" description=""
        local snap_path="${SNAPSHOT_DIR}/${name}"
        if $in_rsync && [[ -f "${snap_path}/info.conf" ]]; then
            size=$(du -sh "${snap_path}" 2>/dev/null | cut -f1)
            description=$(grep "^DESCRIPTION=" "${snap_path}/info.conf" | cut -d= -f2-)
            if is_locked "$snap_path"; then
                lock_status="LOCKED"
            fi
        fi

        printf "%-4s %-36s %-8s %-12s %-10s %-6s %s\n" "$i" "$name" "$type_label" "$storage" "$size" "$lock_status" "$description"
        i=$((i + 1))
    done <<< "$sorted_names"

    echo ""

    # Storage summary
    if [[ -d "$BORG_REPO" ]] && borg_is_available; then
        local repo_size
        repo_size=$(du -sh "$BORG_REPO" 2>/dev/null | cut -f1)
        echo -e "  ${CYAN}Archive storage:${NC} ${repo_size} (deduplicated)"
    fi
    local total_size
    total_size=$(du -sh "$SNAPSHOT_DIR" 2>/dev/null | cut -f1)
    echo -e "  ${CYAN}Total storage:${NC} ${total_size}"
    echo ""
}

delete_snapshot() {
    local target="$1"
    check_root

    # Path traversal protection
    if [[ "$target" == *"/"* || "$target" == *".."* ]]; then
        echo -e "${RED}Error: Invalid snapshot name: ${target}${NC}"
        exit 1
    fi

    local snap_path="${SNAPSHOT_DIR}/${target}"
    local in_rsync=false
    local in_borg=false

    [[ -d "$snap_path" ]] && in_rsync=true
    if [[ -d "$BORG_REPO" ]] && borg_is_available; then
        borg list --short "$BORG_REPO" 2>/dev/null | grep -qx "$target" && in_borg=true
    fi

    if ! $in_rsync && ! $in_borg; then
        echo -e "${RED}Error: Snapshot not found: ${target}${NC}"
        exit 1
    fi

    # Check if local snapshot is locked
    if $in_rsync && is_locked "$snap_path"; then
        echo -e "${RED}Error: This snapshot is locked. Unlock it before deleting:${NC}"
        echo -e "${RED}  sudo snapshot-manager unlock ${target}${NC}"
        exit 1
    fi

    acquire_lock
    trap release_lock EXIT

    # Delete local snapshot if exists
    if $in_rsync; then
        echo -e "${YELLOW}Deleting local snapshot: ${target}${NC}"
        rm -rf "$snap_path"
        echo -e "${GREEN}Local snapshot deleted.${NC}"
    fi

    # Delete archive if exists
    if $in_borg; then
        echo -e "${YELLOW}Deleting archive: ${target}${NC}"
        borg_cmd delete "${BORG_REPO}::${target}"
        echo -e "${GREEN}Archive deleted.${NC}"
    fi

    echo -e "${GREEN}Deleted: ${target}${NC}"

    # Update GRUB only if local snapshot was removed
    if $in_rsync; then
        echo -e "${YELLOW}Updating GRUB menu...${NC}"
        if command -v update-grub &>/dev/null; then
            update-grub 2>&1 | tail -5
        elif command -v grub-mkconfig &>/dev/null; then
            grub-mkconfig -o /boot/grub/grub.cfg 2>&1 | tail -5
        fi
        echo -e "${GREEN}GRUB menu updated.${NC}"
    fi
}

restore_snapshot() {
    local target="$1"
    check_root

    # Path traversal protection
    if [[ "$target" == *"/"* || "$target" == *".."* ]]; then
        echo -e "${RED}Error: Invalid snapshot name: ${target}${NC}"
        exit 1
    fi

    local snap_path="${SNAPSHOT_DIR}/${target}"

    # If already available locally, nothing to do
    if [[ -d "$snap_path" && -d "${snap_path}/fs" ]]; then
        echo -e "${GREEN}Snapshot is already available locally: ${target}${NC}"
        echo -e "${GREEN}Reboot and select 'Snapshot Restore >' in the GRUB menu.${NC}"
        return 0
    fi

    # Check if it's in the archive
    if ! borg_is_available || [[ ! -d "$BORG_REPO" ]]; then
        echo -e "${RED}Error: Snapshot not found: ${target}${NC}"
        exit 1
    fi

    if ! borg list --short "$BORG_REPO" 2>/dev/null | grep -qx "$target"; then
        echo -e "${RED}Error: Snapshot not found: ${target}${NC}"
        exit 1
    fi

    acquire_lock
    trap release_lock EXIT

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Restoring archived snapshot${NC}"
    echo -e "${BLUE}  Name: ${target}${NC}"
    echo -e "${BLUE}============================================${NC}"
    echo ""

    # Extract to temp dir first (safe against partial extraction)
    local tmp_path="${SNAPSHOT_DIR}/.tmp-restore-$$"
    mkdir -p "${tmp_path}/fs"
    mkdir -p "${tmp_path}/boot"

    # Cleanup temp dir on failure/interruption
    trap 'rm -rf "$tmp_path" 2>/dev/null; release_lock' EXIT

    echo -e "${YELLOW}Extracting from archive...${NC}"
    local extract_exit=0
    (cd "${tmp_path}/fs" && borg extract --progress "${BORG_REPO}::${target}") || extract_exit=$?

    if [[ $extract_exit -ne 0 ]]; then
        echo -e "${RED}Error: Extraction failed (exit code: $extract_exit)${NC}"
        rm -rf "$tmp_path"
        exit 1
    fi

    # Copy kernel and initramfs from extracted snapshot
    local kernel_version
    kernel_version=$(uname -r)
    if [[ -f "${tmp_path}/fs/boot/vmlinuz-${kernel_version}" ]]; then
        cp "${tmp_path}/fs/boot/vmlinuz-${kernel_version}" "${tmp_path}/boot/vmlinuz"
    elif [[ -f "/boot/vmlinuz-${kernel_version}" ]]; then
        cp "/boot/vmlinuz-${kernel_version}" "${tmp_path}/boot/vmlinuz"
    elif [[ -f "/boot/vmlinuz" ]]; then
        cp "/boot/vmlinuz" "${tmp_path}/boot/vmlinuz"
    fi

    if [[ -f "${tmp_path}/fs/boot/initrd.img-${kernel_version}" ]]; then
        cp "${tmp_path}/fs/boot/initrd.img-${kernel_version}" "${tmp_path}/boot/initrd.img"
    elif [[ -f "/boot/initrd.img-${kernel_version}" ]]; then
        cp "/boot/initrd.img-${kernel_version}" "${tmp_path}/boot/initrd.img"
    elif [[ -f "/boot/initrd.img" ]]; then
        cp "/boot/initrd.img" "${tmp_path}/boot/initrd.img"
    fi

    # Determine type from name
    local type="system"
    [[ "$target" == full_* ]] && type="full"

    # Extract date from name
    local datepart
    datepart=$(echo "$target" | sed "s/^${type}_//")

    # Create info.conf
    cat > "${tmp_path}/info.conf" <<METAEOF
NAME=${target}
TYPE=${type}
DATE=${datepart}
KERNEL=${kernel_version}
DESCRIPTION=Restored from archive
LOCKED=false
METAEOF

    # Rename temp to final (atomic on same filesystem)
    mv "$tmp_path" "$snap_path"

    echo ""
    echo -e "${GREEN}Snapshot restored: ${target}${NC}"

    local size
    size=$(du -sh "${snap_path}" 2>/dev/null | cut -f1)
    echo -e "${GREEN}Size: ${size}${NC}"

    # Update GRUB
    echo ""
    echo -e "${YELLOW}Updating GRUB menu...${NC}"
    if command -v update-grub &>/dev/null; then
        update-grub 2>&1 | tail -5
    elif command -v grub-mkconfig &>/dev/null; then
        grub-mkconfig -o /boot/grub/grub.cfg 2>&1 | tail -5
    fi
    echo -e "${GREEN}GRUB menu updated. Reboot and select 'Snapshot Restore >' to restore.${NC}"
}

check_integrity() {
    check_root
    ensure_snapshot_dir

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Integrity Check${NC}"
    echo -e "${BLUE}============================================${NC}"
    echo ""

    # Check local snapshots
    local snapshots
    snapshots=$(find "$SNAPSHOT_DIR" -maxdepth 1 -mindepth 1 -type d ! -name ".*" 2>/dev/null | sort -r)

    if [[ -n "$snapshots" ]]; then
        echo -e "${CYAN}Local snapshots:${NC}"
        for snap in $snapshots; do
            local name
            name=$(basename "$snap")
            if [[ -f "${snap}/info.conf" && -d "${snap}/fs" && -f "${snap}/boot/vmlinuz" ]]; then
                echo -e "  ${GREEN}[OK]${NC} ${name}"
            else
                local issues=""
                [[ ! -f "${snap}/info.conf" ]] && issues+="info.conf "
                [[ ! -d "${snap}/fs" ]] && issues+="fs/ "
                [[ ! -f "${snap}/boot/vmlinuz" ]] && issues+="vmlinuz "
                echo -e "  ${RED}[WARN]${NC} ${name} (missing: ${issues})"
            fi
        done
        echo ""
    fi

    # Check archive repository
    if [[ -d "$BORG_REPO" ]] && borg_is_available; then
        echo -e "${CYAN}Archive repository:${NC} ${BORG_REPO}"
        echo ""
        echo -e "${YELLOW}Checking repository integrity...${NC}"
        local check_exit=0
        borg_cmd check --progress "$BORG_REPO" || check_exit=$?

        echo ""
        if [[ $check_exit -eq 0 ]]; then
            echo -e "${GREEN}Repository integrity check passed.${NC}"
        elif [[ $check_exit -eq 1 ]]; then
            echo -e "${YELLOW}Check completed with warnings.${NC}"
        else
            echo -e "${RED}Repository check FAILED (exit code: $check_exit)${NC}"
        fi
    else
        echo -e "${YELLOW}No archive repository found.${NC}"
    fi
}

lock_snapshot() {
    local target="$1"
    check_root

    if [[ "$target" == *"/"* || "$target" == *".."* ]]; then
        echo -e "${RED}Error: Invalid snapshot name: ${target}${NC}"
        exit 1
    fi

    local snap_path="${SNAPSHOT_DIR}/${target}"
    if [[ ! -d "$snap_path" || ! -f "${snap_path}/info.conf" ]]; then
        echo -e "${RED}Error: Snapshot not found: ${target}${NC}"
        exit 1
    fi

    if is_locked "$snap_path"; then
        echo -e "${YELLOW}Snapshot is already locked: ${target}${NC}"
        return
    fi

    if grep -q "^LOCKED=" "${snap_path}/info.conf"; then
        sed -i 's/^LOCKED=.*/LOCKED=true/' "${snap_path}/info.conf"
    else
        echo "LOCKED=true" >> "${snap_path}/info.conf"
    fi

    echo -e "${GREEN}Snapshot locked: ${target}${NC}"
    echo -e "${GREEN}This snapshot will be protected from automatic cleanup.${NC}"
}

unlock_snapshot() {
    local target="$1"
    check_root

    if [[ "$target" == *"/"* || "$target" == *".."* ]]; then
        echo -e "${RED}Error: Invalid snapshot name: ${target}${NC}"
        exit 1
    fi

    local snap_path="${SNAPSHOT_DIR}/${target}"
    if [[ ! -d "$snap_path" || ! -f "${snap_path}/info.conf" ]]; then
        echo -e "${RED}Error: Snapshot not found: ${target}${NC}"
        exit 1
    fi

    if ! is_locked "$snap_path"; then
        echo -e "${YELLOW}Snapshot is already unlocked: ${target}${NC}"
        return
    fi

    sed -i 's/^LOCKED=.*/LOCKED=false/' "${snap_path}/info.conf"
    echo -e "${GREEN}Snapshot unlocked: ${target}${NC}"
}

diff_snapshots() {
    local snap1="$1"
    local snap2="$2"

    # Path traversal protection
    for s in "$snap1" "$snap2"; do
        if [[ "$s" == *"/"* || "$s" == *".."* ]]; then
            echo -e "${RED}Error: Invalid snapshot name: ${s}${NC}"
            exit 1
        fi
    done

    local path1="${SNAPSHOT_DIR}/${snap1}/fs/"
    local path2="${SNAPSHOT_DIR}/${snap2}/fs/"

    if [[ ! -d "$path1" ]]; then
        echo -e "${RED}Error: Snapshot not found: ${snap1}${NC}"
        exit 1
    fi
    if [[ ! -d "$path2" ]]; then
        echo -e "${RED}Error: Snapshot not found: ${snap2}${NC}"
        exit 1
    fi

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Snapshot Comparison${NC}"
    echo -e "${BLUE}  ${snap1} -> ${snap2}${NC}"
    echo -e "${BLUE}============================================${NC}"
    echo ""

    local added=0 deleted=0 changed=0

    # rsync dry-run itemize output
    local diff_output
    diff_output=$(rsync -aniH --delete "$path1" "$path2" 2>/dev/null || true)

    if [[ -z "$diff_output" ]]; then
        echo -e "${GREEN}No differences found between the two snapshots.${NC}"
        return
    fi

    echo -e "${CYAN}Changes:${NC}"
    echo ""

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue

        # Deleting lines have format: "*deleting   path/to/file"
        if [[ "$line" == *deleting* ]]; then
            local del_path="${line#*deleting   }"
            # Skip directory deletions
            [[ "$del_path" == */ ]] && continue
            echo -e "  ${RED}[-] ${del_path}${NC}"
            deleted=$((deleted + 1))
            continue
        fi

        local flag="${line:0:11}"
        local filepath="${line:12}"

        # Skip directory-only entries
        [[ "$filepath" == */ ]] && continue

        if [[ "${flag:0:1}" == ">" ]]; then
            if [[ "${flag:2:1}" == "+" || "${flag:3:1}" == "+" ]]; then
                echo -e "  ${GREEN}[+] ${filepath}${NC}"
                added=$((added + 1))
            else
                echo -e "  ${YELLOW}[~] ${filepath}${NC}"
                changed=$((changed + 1))
            fi
        elif [[ "${flag:0:1}" == "<" || "${flag:0:1}" == "c" ]]; then
            echo -e "  ${YELLOW}[~] ${filepath}${NC}"
            changed=$((changed + 1))
        fi
    done <<< "$diff_output"

    echo ""
    echo -e "${BLUE}Summary: ${GREEN}+${added} added${NC}, ${YELLOW}~${changed} changed${NC}, ${RED}-${deleted} deleted${NC}"
}

restore_file_cmd() {
    local snapshot="$1"
    local filepath="$2"
    local destination="${3:-}"

    check_root

    # Path traversal protection for snapshot name
    if [[ "$snapshot" == *"/"* || "$snapshot" == *".."* ]]; then
        echo -e "${RED}Error: Invalid snapshot name: ${snapshot}${NC}"
        exit 1
    fi

    # Normalize filepath (remove leading slash for snapshot path)
    filepath="${filepath#/}"

    # Path traversal protection for file path
    if [[ "$filepath" == *".."* ]]; then
        echo -e "${RED}Error: Invalid file path: ${filepath}${NC}"
        exit 1
    fi

    local snap_file="${SNAPSHOT_DIR}/${snapshot}/fs/${filepath}"

    if [[ ! -e "$snap_file" ]]; then
        echo -e "${RED}Error: File not found in snapshot: /${filepath}${NC}"
        exit 1
    fi

    if [[ -z "$destination" ]]; then
        destination="/${filepath}"
    fi

    # Create parent directory if needed
    local dest_dir
    dest_dir=$(dirname "$destination")
    mkdir -p "$dest_dir"

    # Backup current file if it exists
    if [[ -e "$destination" ]]; then
        local backup="${destination}.pre-restore.$(date +%s)"
        cp -a "$destination" "$backup"
        echo -e "${YELLOW}Current file backed up: ${backup}${NC}"
    fi

    cp -a "$snap_file" "$destination"
    echo -e "${GREEN}Restored: /${filepath} -> ${destination}${NC}"
}

verify_snapshot() {
    local target="$1"

    if [[ "$target" == *"/"* || "$target" == *".."* ]]; then
        echo -e "${RED}Error: Invalid snapshot name: ${target}${NC}"
        exit 1
    fi

    local snap_path="${SNAPSHOT_DIR}/${target}"
    if [[ ! -d "$snap_path" || ! -f "${snap_path}/info.conf" ]]; then
        echo -e "${RED}Error: Snapshot not found: ${target}${NC}"
        exit 1
    fi

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Snapshot Verification: ${target}${NC}"
    echo -e "${BLUE}============================================${NC}"
    echo ""

    # Show snapshot info
    local name type date kernel description size
    name=$(grep "^NAME=" "${snap_path}/info.conf" | cut -d= -f2-)
    type=$(grep "^TYPE=" "${snap_path}/info.conf" | cut -d= -f2-)
    date=$(grep "^DATE=" "${snap_path}/info.conf" | cut -d= -f2-)
    kernel=$(grep "^KERNEL=" "${snap_path}/info.conf" | cut -d= -f2-)
    description=$(grep "^DESCRIPTION=" "${snap_path}/info.conf" | cut -d= -f2-)
    size=$(du -sh "${snap_path}" 2>/dev/null | cut -f1)

    echo -e "  Name        : ${name}"
    echo -e "  Type        : ${type}"
    echo -e "  Date        : ${date}"
    echo -e "  Kernel      : ${kernel}"
    echo -e "  Size        : ${size}"
    echo -e "  Description : ${description}"
    if is_locked "$snap_path"; then
        echo -e "  Lock        : ${GREEN}LOCKED${NC}"
    fi
    echo ""

    # Check essential files
    echo -e "${YELLOW}Checking essential files...${NC}"
    local ok=0 missing=0

    for f in "fs" "boot/vmlinuz" "boot/initrd.img" "info.conf"; do
        if [[ -e "${snap_path}/${f}" ]]; then
            echo -e "  ${GREEN}[OK]${NC} ${f}"
            ok=$((ok + 1))
        else
            echo -e "  ${RED}[MISSING]${NC} ${f}"
            missing=$((missing + 1))
        fi
    done
    echo ""

    # Check key system directories in snapshot
    echo -e "${YELLOW}Checking system directories...${NC}"
    for d in "fs/etc" "fs/usr" "fs/var" "fs/bin" "fs/sbin" "fs/lib"; do
        if [[ -d "${snap_path}/${d}" ]]; then
            local fcount
            fcount=$(find "${snap_path}/${d}" -maxdepth 1 | wc -l)
            echo -e "  ${GREEN}[OK]${NC} /${d#fs/} (${fcount} items)"
            ok=$((ok + 1))
        else
            # /bin, /sbin, /lib might be symlinks to /usr on modern systems
            if [[ -L "${snap_path}/${d}" ]]; then
                echo -e "  ${GREEN}[OK]${NC} /${d#fs/} (symlink)"
                ok=$((ok + 1))
            else
                echo -e "  ${YELLOW}[N/A]${NC} /${d#fs/}"
            fi
        fi
    done
    echo ""

    # If manifest exists, verify it
    if [[ -f "${snap_path}/manifest.sha256" ]]; then
        echo -e "${YELLOW}Verifying SHA256 manifest...${NC}"
        echo -e "${YELLOW}(This may take a while)${NC}"
        local total verified failed
        total=$(wc -l < "${snap_path}/manifest.sha256")
        failed=0

        while IFS= read -r line; do
            if ! echo "$line" | sha256sum -c --quiet 2>/dev/null; then
                local bad_file
                bad_file=$(echo "$line" | awk '{print $2}')
                echo -e "  ${RED}[CORRUPT]${NC} ${bad_file}"
                failed=$((failed + 1))
            fi
        done < "${snap_path}/manifest.sha256"

        verified=$((total - failed))
        echo ""
        echo -e "  Total: ${total}, ${GREEN}Valid: ${verified}${NC}, ${RED}Corrupt: ${failed}${NC}"
    else
        echo -e "${YELLOW}SHA256 manifest not found. To generate a manifest:${NC}"
        echo -e "  Add GENERATE_MANIFEST=true to /etc/snapshot-manager.conf"
    fi

    echo ""
    if [[ $missing -eq 0 ]]; then
        echo -e "${GREEN}Snapshot appears to be valid.${NC}"
    else
        echo -e "${RED}WARNING: ${missing} essential files are missing!${NC}"
    fi
}

show_status() {
    ensure_snapshot_dir

    echo -e "${BLUE}============================================${NC}"
    echo -e "${BLUE}  Snapshot Manager Status${NC}"
    echo -e "${BLUE}============================================${NC}"
    echo ""

    # Disk info
    local root_total root_used root_avail root_pct
    root_total=$(df -h --output=size / | tail -1 | tr -d ' ')
    root_used=$(df -h --output=used / | tail -1 | tr -d ' ')
    root_avail=$(df -h --output=avail / | tail -1 | tr -d ' ')
    root_pct=$(df --output=pcent / | tail -1 | tr -d ' ')

    echo -e "  ${CYAN}Disk Status:${NC}"
    echo -e "    Total     : ${root_total}"
    echo -e "    Used      : ${root_used} (${root_pct})"
    echo -e "    Free      : ${root_avail}"
    echo ""

    # Snapshot directory size
    local snap_size
    snap_size=$(du -sh "$SNAPSHOT_DIR" 2>/dev/null | cut -f1)
    echo -e "  ${CYAN}Snapshot Storage:${NC} ${snap_size}"

    # Snapshot counts
    local sys_count full_count total_count locked_count
    sys_count=$(find "$SNAPSHOT_DIR" -maxdepth 1 -name "system_*" -type d 2>/dev/null | wc -l)
    full_count=$(find "$SNAPSHOT_DIR" -maxdepth 1 -name "full_*" -type d 2>/dev/null | wc -l)
    total_count=$((sys_count + full_count))
    locked_count=0
    for snap in "$SNAPSHOT_DIR"/*/; do
        [[ -d "$snap" ]] && is_locked "$snap" && locked_count=$((locked_count + 1))
    done

    echo -e "  ${CYAN}Snapshot Count:${NC}"
    echo -e "    System    : ${sys_count}"
    echo -e "    Full      : ${full_count}"
    echo -e "    Total     : ${total_count}"
    echo -e "    Locked    : ${locked_count}"
    echo ""

    # Archive info
    if [[ -d "$BORG_REPO" ]] && borg_is_available; then
        local archive_count archive_size
        archive_count=$(borg list --short "$BORG_REPO" 2>/dev/null | wc -l)
        archive_size=$(du -sh "$BORG_REPO" 2>/dev/null | cut -f1)
        echo -e "  ${CYAN}Archived Snapshots:${NC}"
        echo -e "    Count     : ${archive_count}"
        echo -e "    Size      : ${archive_size} (deduplicated)"
        echo ""
    fi

    # Config summary
    echo -e "  ${CYAN}Configuration:${NC}"
    echo -e "    Directory        : ${SNAPSHOT_DIR}"
    echo -e "    Archive mode     : ${ARCHIVE_MODE}"
    if [[ "$ARCHIVE_MODE" == "borg" ]]; then
        echo -e "    Compression      : ${BORG_COMPRESSION}"
        echo -e "    Max local kept   : ${MAX_RECENT_RSYNC}"
        echo -e "    Keep daily       : ${BORG_KEEP_DAILY}"
        echo -e "    Keep weekly      : ${BORG_KEEP_WEEKLY}"
        echo -e "    Keep monthly     : ${BORG_KEEP_MONTHLY}"
    else
        echo -e "    Max System       : ${MAX_SYSTEM_SNAPSHOTS} (0=unlimited)"
        echo -e "    Max Full         : ${MAX_FULL_SNAPSHOTS} (0=unlimited)"
        echo -e "    Daily retention  : ${KEEP_DAILY} (0=disabled)"
        echo -e "    Weekly retention : ${KEEP_WEEKLY} (0=disabled)"
        echo -e "    Monthly retention: ${KEEP_MONTHLY} (0=disabled)"
    fi
    echo -e "    Low priority     : ${LOW_PRIORITY}"
    echo -e "    SHA256 manifest  : ${GENERATE_MANIFEST}"
    echo ""

    # Timer status
    if systemctl is-active snapshot-daily.timer &>/dev/null; then
        echo -e "  ${CYAN}Scheduled Backups:${NC}"
        echo -e "    Daily timer   : ${GREEN}active${NC}"
    else
        echo -e "  ${CYAN}Scheduled Backups:${NC}"
        echo -e "    Daily timer   : ${YELLOW}disabled${NC}"
    fi
    if systemctl is-active snapshot-weekly.timer &>/dev/null; then
        echo -e "    Weekly timer  : ${GREEN}active${NC}"
    else
        echo -e "    Weekly timer  : ${YELLOW}disabled${NC}"
    fi
    echo ""
}

show_help() {
    echo "Snapshot Manager - rsync+hardlink snapshot system with GRUB restore"
    echo ""
    echo "Usage:"
    echo "  sudo snapshot-manager create [system|full] [description]"
    echo "  sudo snapshot-manager list"
    echo "  sudo snapshot-manager delete <snapshot_name>"
    echo "  sudo snapshot-manager restore <snapshot_name>"
    echo "  sudo snapshot-manager verify <snapshot_name>"
    echo "  sudo snapshot-manager check"
    echo "  sudo snapshot-manager lock <snapshot_name>"
    echo "  sudo snapshot-manager unlock <snapshot_name>"
    echo "  sudo snapshot-manager diff <snapshot1> <snapshot2>"
    echo "  sudo snapshot-manager restore-file <snapshot> <file_path> [destination]"
    echo "  sudo snapshot-manager archive <snapshot_name>"
    echo "  sudo snapshot-manager status"
    echo "  sudo snapshot-manager help"
    echo ""
    echo "Commands:"
    echo "  create       Create a new snapshot (system or full)"
    echo "  list         List all snapshots (local and archived)"
    echo "  delete       Delete a snapshot (from local and/or archive)"
    echo "  restore      Restore an archived snapshot for GRUB boot restore"
    echo "  verify       Verify snapshot files and structure"
    echo "  check        Run integrity check on all snapshots and archives"
    echo "  lock/unlock  Protect a snapshot from automatic cleanup"
    echo "  diff         Compare two snapshots"
    echo "  restore-file Restore a single file from a snapshot"
    echo "  archive      Manually archive a local snapshot"
    echo "  status       Show system and snapshot status"
    echo ""
    echo "Examples:"
    echo "  sudo snapshot-manager create system"
    echo "  sudo snapshot-manager create full \"Before major update\""
    echo "  sudo snapshot-manager list"
    echo "  sudo snapshot-manager delete system_2026-03-08_14-30-00"
    echo "  sudo snapshot-manager restore system_2026-03-08_14-30-00"
    echo "  sudo snapshot-manager check"
    echo ""
    echo "Snapshot Types:"
    echo "  system  - System files (excluding /home)"
    echo "  full    - All files (including /home)"
    echo ""
    echo "Storage:"
    echo "  local     - Snapshot is on disk, ready for GRUB boot restore"
    echo "  archived  - Snapshot is in archive (deduplicated, compressed)"
    echo "              Use 'restore' to extract before GRUB boot restore"
    echo ""
    echo "Full Restore:"
    echo "  Reboot and select 'Snapshot Restore >' in the GRUB menu."
    echo "  For archived snapshots: first run 'restore' to extract,"
    echo "  then reboot and select from GRUB."
    echo ""
    echo "Single File Restore:"
    echo "  sudo snapshot-manager restore-file <snapshot> <file_path>"
}

# Main
case "${1:-help}" in
    create)
        create_snapshot "${2:-system}" "${3:-}"
        ;;
    list)
        list_snapshots
        ;;
    delete)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Specify the snapshot name to delete.${NC}"
            exit 1
        fi
        delete_snapshot "$2"
        ;;
    restore)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Specify the snapshot name to restore.${NC}"
            exit 1
        fi
        restore_snapshot "$2"
        ;;
    lock)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Specify the snapshot name to lock.${NC}"
            exit 1
        fi
        lock_snapshot "$2"
        ;;
    unlock)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Specify the snapshot name to unlock.${NC}"
            exit 1
        fi
        unlock_snapshot "$2"
        ;;
    diff)
        if [[ -z "${2:-}" || -z "${3:-}" ]]; then
            echo -e "${RED}Error: Specify two snapshot names.${NC}"
            echo "Usage: snapshot-manager diff <snapshot1> <snapshot2>"
            exit 1
        fi
        diff_snapshots "$2" "$3"
        ;;
    restore-file)
        if [[ -z "${2:-}" || -z "${3:-}" ]]; then
            echo -e "${RED}Error: Specify snapshot name and file path.${NC}"
            echo "Usage: snapshot-manager restore-file <snapshot> <file_path> [destination]"
            exit 1
        fi
        restore_file_cmd "$2" "$3" "${4:-}"
        ;;
    verify)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Specify the snapshot name to verify.${NC}"
            exit 1
        fi
        verify_snapshot "$2"
        ;;
    check)
        check_integrity
        ;;
    status)
        show_status
        ;;
    archive)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Specify the snapshot name to archive.${NC}"
            exit 1
        fi
        archive_to_borg "$2"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo -e "${RED}Error: Unknown command: $1${NC}"
        show_help
        exit 1
        ;;
esac
